# =============================================================================
# Pelican Trading AI — Environment Variables
# =============================================================================
# Copy to .env.local and fill in real values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser — never put secrets there.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Required)
# Project: ewcqmsfaostcwmgybbub — Region: us-east-2
# Dashboard: https://supabase.com/dashboard/project/ewcqmsfaostcwmgybbub
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Pelican Backend API (Required)
# Python backend on Fly.io — handles chat streaming via SSE
# -----------------------------------------------------------------------------
PEL_API_KEY=your_pelican_api_key_here
NEXT_PUBLIC_BACKEND_URL=https://pelican-backend.fly.dev

# -----------------------------------------------------------------------------
# OpenAI (Required)
# Used by: /api/education-chat, /api/help-chat, /api/conversations/[id]/generate-title
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here

# -----------------------------------------------------------------------------
# Polygon.io (Required)
# Market data: heatmap, candles, movers, quotes, sparklines, IPOs, earnings
# -----------------------------------------------------------------------------
POLYGON_API_KEY=your_polygon_api_key_here

# -----------------------------------------------------------------------------
# Stripe (Required)
# Payments: checkout, billing portal, webhook signature verification
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_id_here
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_id_here
NEXT_PUBLIC_STRIPE_POWER_PRICE_ID=price_power_id_here

# -----------------------------------------------------------------------------
# Upstash Redis (Required)
# Rate limiting for 25+ API routes. Fails CLOSED when unavailable.
# Dashboard: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# -----------------------------------------------------------------------------
# Finnhub (Required)
# Earnings data for the earnings calendar
# -----------------------------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_api_key_here

# -----------------------------------------------------------------------------
# Vercel Cron (Required in production)
# Protects /api/cron/* routes from unauthorized access
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret_here

# -----------------------------------------------------------------------------
# App URL (Required)
# Used for Stripe redirect URLs and OG meta. Set per-environment in Vercel dashboard.
# Production: https://pelicantrading.ai
# Staging: https://pelicantrading.org
# Local: http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Resend (Optional)
# Email sending — only needed if email features are enabled
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_your_resend_key_here

# -----------------------------------------------------------------------------
# Sentry (Optional — auto-configured on Vercel via integration)
# Error tracking and performance monitoring
# -----------------------------------------------------------------------------
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# -----------------------------------------------------------------------------
# Signup shutdown flags
# When NEXT_PUBLIC_SIGNUP_CLOSED=true: /auth/signup redirects to /waitlist,
# landing CTAs route to /waitlist, and OAuth users created after the cutoff
# are blocked and deleted. Set SIGNUP_CUTOFF_TIMESTAMP to the deploy moment
# (ISO 8601) so existing users aren't caught in the OAuth block.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SIGNUP_CLOSED=false
SIGNUP_CUTOFF_TIMESTAMP=
